<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/17.0.2"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.projectmanagement.controller.ReportsController"
      spacing="15"
      style="-fx-background-color: #f5f6fa;">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <!-- Заголовок и кнопки -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="📈 Отчеты и аналитика" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="🔄 Обновить" onAction="#handleRefreshReports"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15;" />
        <Button text="📥 Экспорт" onAction="#handleExportReports"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15;" />
    </HBox>

    <!-- Быстрые метрики -->
    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints percentWidth="16" />
            <ColumnConstraints percentWidth="16" />
            <ColumnConstraints percentWidth="16" />
            <ColumnConstraints percentWidth="16" />
            <ColumnConstraints percentWidth="16" />
            <ColumnConstraints percentWidth="16" />
        </columnConstraints>

        <rowConstraints>
            <RowConstraints />
        </rowConstraints>

        <!-- Метрика 1 -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);"
              alignment="CENTER" GridPane.columnIndex="0">
            <Label text="🏢 Проекты" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
            <Label fx:id="lblTotalProjects" text="0"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3498db;" />
            <Label text="Всего" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" />
        </VBox>

        <!-- Метрика 2 -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);"
              alignment="CENTER" GridPane.columnIndex="1">
            <Label text="✅ Задачи" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
            <Label fx:id="lblTotalTasks" text="0"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;" />
            <Label text="Всего" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" />
        </VBox>

        <!-- Метрика 3 -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);"
              alignment="CENTER" GridPane.columnIndex="2">
            <Label text="🚀 Активные" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
            <Label fx:id="lblActiveProjects" text="0"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f39c12;" />
            <Label text="Проекты" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" />
        </VBox>

        <!-- Метрика 4 -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);"
              alignment="CENTER" GridPane.columnIndex="3">
            <Label text="⚠️ Просрочено" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
            <Label fx:id="lblOverdueTasks" text="0"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" />
            <Label text="Задач" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" />
        </VBox>

        <!-- Метрика 5 -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);"
              alignment="CENTER" GridPane.columnIndex="4">
            <Label text="🔴 Высокий" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
            <Label fx:id="lblHighPriorityTasks" text="0"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" />
            <Label text="Приоритет" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" />
        </VBox>

        <!-- Метрика 6 -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);"
              alignment="CENTER" GridPane.columnIndex="5">
            <Label text="🎯 Завершено" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
            <Label fx:id="lblCompletedTasks" text="0"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
            <Label text="Задач" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" />
        </VBox>
    </GridPane>

    <!-- Вкладки с отчетами -->
    <TabPane fx:id="reportTabs" VBox.vgrow="ALWAYS">

        <!-- Вкладка 1: Основные графики -->
        <Tab text="📊 Основная статистика">
            <ScrollPane fitToWidth="true" fitToHeight="true">
                <VBox spacing="20">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>

                    <!-- График статусов проектов -->
                    <VBox spacing="5">
                        <Label text="Статусы проектов" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                        <BarChart fx:id="bcProjectsStatus" prefHeight="250">
                            <xAxis>
                                <CategoryAxis label="Статусы" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Количество" />
                            </yAxis>
                        </BarChart>
                    </VBox>

                    <!-- График приоритетов задач -->
                    <VBox spacing="5">
                        <Label text="Приоритеты задач" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                        <PieChart fx:id="pcTasksPriority" prefHeight="250" />
                    </VBox>

                    <!-- График задач по проектам -->
                    <VBox spacing="5">
                        <Label text="Задачи по проектам" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                        <BarChart fx:id="bcTasksPerProject" prefHeight="250">
                            <xAxis>
                                <CategoryAxis label="Проекты" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Количество задач" />
                            </yAxis>
                        </BarChart>
                    </VBox>
                </VBox>
            </ScrollPane>
        </Tab>

        <!-- Вкладка 2: Прогнозирование -->
        <Tab text="📈 Прогнозирование">
            <ScrollPane fitToWidth="true" fitToHeight="true">
                <VBox spacing="20">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>

                    <!-- Метрики прогнозирования -->
                    <GridPane hgap="10" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="20" />
                            <ColumnConstraints percentWidth="20" />
                            <ColumnConstraints percentWidth="20" />
                            <ColumnConstraints percentWidth="20" />
                            <ColumnConstraints percentWidth="20" />
                        </columnConstraints>

                        <!-- Прогноз на следующую неделю -->
                        <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);"
                              alignment="CENTER" GridPane.columnIndex="0">
                            <Label text="📅 Прогноз" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                            <Label fx:id="lblForecastValue" text="0"
                                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3498db;" />
                            <Label text="задач/неделю" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" />
                        </VBox>

                        <!-- Темп роста -->
                        <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);"
                              alignment="CENTER" GridPane.columnIndex="1">
                            <Label text="📈 Рост" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                            <Label fx:id="lblGrowthRate" text="0%"
                                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;" />
                            <Label text="темп роста" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" />
                        </VBox>

                        <!-- Среднее выполнение -->
                        <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);"
                              alignment="CENTER" GridPane.columnIndex="2">
                            <Label text="📊 Среднее" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                            <Label fx:id="lblAverageCompletion" text="0"
                                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f39c12;" />
                            <Label text="задач/неделю" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" />
                        </VBox>

                        <!-- Выполнение в срок -->
                        <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);"
                              alignment="CENTER" GridPane.columnIndex="3">
                            <Label text="⏰ В срок" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                            <Label fx:id="lblOnTimeRate" text="0%"
                                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
                            <Label text="выполнение" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" />
                        </VBox>

                        <!-- Точность оценки -->
                        <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);"
                              alignment="CENTER" GridPane.columnIndex="4">
                            <Label text="🎯 Точность" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                            <Label fx:id="lblEstimationAccuracy" text="0%"
                                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #9b59b6;" />
                            <Label text="оценки" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" />
                        </VBox>
                    </GridPane>

                    <!-- График выполнения по неделям -->
                    <VBox spacing="5">
                        <Label text="📅 Выполнение задач по неделям" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                        <BarChart fx:id="bcWeeklyCompletion" prefHeight="300">
                            <xAxis>
                                <CategoryAxis label="Недели" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Количество выполненных задач" />
                            </yAxis>
                        </BarChart>
                    </VBox>

                    <!-- Тренд выполнения -->
                    <VBox spacing="5">
                        <Label text="📈 Тренд выполнения задач" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                        <LineChart fx:id="lcCompletionTrend" prefHeight="300">
                            <xAxis>
                                <CategoryAxis label="Недели" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Выполнено задач" />
                            </yAxis>
                        </LineChart>
                    </VBox>

                    <!-- Рекомендации -->
                    <VBox spacing="5">
                        <Label text="💡 Рекомендации и аналитика" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                        <ListView fx:id="lvRecommendations" prefHeight="150" />
                    </VBox>
                </VBox>
            </ScrollPane>
        </Tab>

        <!-- Вкладка 3: Просроченные задачи -->
        <Tab text="⚠️ Просроченные задачи">
            <ScrollPane fitToWidth="true" fitToHeight="true">
                <VBox spacing="10">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>

                    <Label text="Список просроченных задач" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
                    <ListView fx:id="lvOverdueTasks" VBox.vgrow="ALWAYS" />
                </VBox>
            </ScrollPane>
        </Tab>

        <!-- Вкладка 4: Сводка задач -->
        <Tab text="📋 Сводка задач">
            <ScrollPane fitToWidth="true" fitToHeight="true">
                <VBox spacing="10">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>

                    <Label text="Детальная сводка задач по проектам" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
                    <TextArea fx:id="taTasksSummary" VBox.vgrow="ALWAYS"
                              editable="false" wrapText="true"
                              style="-fx-font-family: 'Monospaced'; -fx-font-size: 12px;" />
                </VBox>
            </ScrollPane>
        </Tab>

        <!-- Вкладка 5: Статистика -->
        <Tab text="📊 Общая статистика">
            <ScrollPane fitToWidth="true" fitToHeight="true">
                <VBox spacing="10">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>

                    <Label text="Общая статистика системы" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
                    <TextArea fx:id="taSystemStatistics" VBox.vgrow="ALWAYS"
                              editable="false" wrapText="true"
                              style="-fx-font-family: 'Monospaced'; -fx-font-size: 12px;" />
                </VBox>
            </ScrollPane>
        </Tab>

    </TabPane>

</VBox>