<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<GridPane xmlns="http://javafx.com/javafx/17.0.2"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.projectmanagement.controller.ProjectController"
          hgap="15" vgap="15">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <columnConstraints>
        <ColumnConstraints percentWidth="65" />
        <ColumnConstraints percentWidth="35" />
    </columnConstraints>

    <rowConstraints>
        <RowConstraints percentHeight="60" />
        <RowConstraints percentHeight="40" />
    </rowConstraints>

    <!-- Левая часть: Список проектов -->
    <VBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.rowSpan="2">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="📁 Управление проектами" styleClass="header-label">
                <font>
                    <Font name="System Bold" size="18" />
                </font>
            </Label>
            <Label fx:id="lblProjectStats" text=""
                   style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="🔄 Обновить" onAction="#handleRefresh"
                    styleClass="secondary-btn" />
        </HBox>

        <!-- Поиск -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Поиск:" />
            <TextField fx:id="tfSearchProject"
                       promptText="Поиск по названию..."
                       HBox.hgrow="ALWAYS" />
        </HBox>

        <!-- Таблица проектов -->
        <TableView fx:id="projectTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50" />
                <TableColumn fx:id="colName" text="Название" prefWidth="200" />
                <TableColumn fx:id="colManager" text="Руководитель" prefWidth="150" />
                <TableColumn fx:id="colStatus" text="Статус" prefWidth="100" />
                <TableColumn fx:id="colStartDate" text="Дата начала" prefWidth="100" />
                <TableColumn fx:id="colTaskCount" text="Задач" prefWidth="80" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>

    <!-- Правая верхняя часть: Форма проекта -->
    <VBox spacing="15" styleClass="form-panel"
          GridPane.columnIndex="1" GridPane.rowIndex="0">
        <Label text="✏️ Форма проекта" styleClass="header-label">
            <font>
                <Font name="System Bold" size="16" />
            </font>
        </Label>

        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints percentWidth="35" />
                <ColumnConstraints percentWidth="65" />
            </columnConstraints>

            <rowConstraints>
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
            </rowConstraints>

            <!-- Название проекта -->
            <Label text="Название*:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="tfProjectName"
                       promptText="Введите название проекта"
                       GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <!-- Руководитель -->
            <Label text="Руководитель*:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="tfProjectManager"
                       promptText="Введите ФИО руководителя"
                       GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <!-- Статус -->
            <Label text="Статус:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <ComboBox fx:id="cbProjectStatus"
                      GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <!-- Дата начала -->
            <Label text="Дата начала:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <DatePicker fx:id="dpStartDate"
                        promptText="дд.мм.гггг"
                        GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <!-- Дата окончания -->
            <Label text="Дата окончания:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
            <DatePicker fx:id="dpEndDate"
                        promptText="дд.мм.гггг"
                        GridPane.columnIndex="1" GridPane.rowIndex="4" />

            <!-- Бюджет -->
            <Label text="Бюджет:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
            <TextField fx:id="tfBudget"
                       promptText="0.00"
                       GridPane.columnIndex="1" GridPane.rowIndex="5" />
        </GridPane>

        <!-- Описание -->
        <Label text="Описание:" />
        <TextArea fx:id="taProjectDescription"
                  promptText="Описание проекта..."
                  prefRowCount="3" />

        <!-- Кнопки действий -->
        <HBox spacing="10" alignment="CENTER">
            <Button fx:id="btnAddProject" text="➕ Добавить"
                    onAction="#handleAddProject" styleClass="primary-btn" />
            <Button fx:id="btnUpdateProject" text="✏️ Обновить"
                    onAction="#handleUpdateProject" styleClass="secondary-btn"
                    disable="true" />
            <Button fx:id="btnDeleteProject" text="🗑️ Удалить"
                    onAction="#handleDeleteProject" styleClass="danger-btn"
                    disable="true" />
            <Button fx:id="btnClearProject" text="❌ Очистить"
                    onAction="#handleClearForm" styleClass="secondary-btn" />
        </HBox>
    </VBox>

    <!-- Правая нижняя часть: Задачи проекта -->
    <VBox spacing="10" styleClass="form-panel"
          GridPane.columnIndex="1" GridPane.rowIndex="1">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="✅ Задачи проекта" styleClass="header-label">
                <font>
                    <Font name="System Bold" size="16" />
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="➕ Добавить"
                    onAction="#handleAddTaskToProject"
                    styleClass="primary-btn" />
            <Button text="🗑️ Удалить"
                    onAction="#handleDeleteTask"
                    styleClass="danger-btn" />
        </HBox>

        <TableView fx:id="projectTasksTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colTaskId" text="ID" prefWidth="40" />
                <TableColumn fx:id="colTaskName" text="Задача" prefWidth="150" />
                <TableColumn fx:id="colTaskPriority" text="Приоритет" prefWidth="80" />
                <TableColumn fx:id="colTaskStatus" text="Статус" prefWidth="90" />
                <TableColumn fx:id="colTaskAssignee" text="Исполнитель" prefWidth="120" />
            </columns>
            <placeholder>
                <Label text="Выберите проект для просмотра задач" />
            </placeholder>
        </TableView>
    </VBox>

</GridPane>