<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/17.0.2"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.projectmanagement.controller.TaskDialogController"
      spacing="15"
      padding="20"
      prefWidth="400"
      prefHeight="500">

    <Label fx:id="lblProjectName" styleClass="header-label">
        <font>
            <Font name="System Bold" size="16" />
        </font>
    </Label>

    <Separator />

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints percentWidth="35" />
            <ColumnConstraints percentWidth="65" />
        </columnConstraints>

        <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
        </rowConstraints>

        <!-- Название задачи -->
        <Label text="Название*:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="tfTaskTitle"
                   promptText="Введите название задачи"
                   GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <!-- Приоритет -->
        <Label text="Приоритет:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <ComboBox fx:id="cbPriority"
                  GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <!-- Исполнитель -->
        <Label text="Исполнитель*:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <ComboBox fx:id="cbAssignee"
                  GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <!-- Планируемые часы -->
        <Label text="Часы:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <TextField fx:id="tfEstimatedHours"
                   promptText="0"
                   GridPane.columnIndex="1" GridPane.rowIndex="3" />

        <!-- Дедлайн -->
        <Label text="Дедлайн*:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <DatePicker fx:id="dpDeadline"
                    promptText="дд.мм.гггг"
                    GridPane.columnIndex="1" GridPane.rowIndex="4" />
    </GridPane>

    <!-- Описание -->
    <Label text="Описание:" />
    <TextArea fx:id="taTaskDescription"
              promptText="Описание задачи..."
              prefRowCount="4" />

    <!-- Кнопки -->
    <HBox spacing="10" alignment="CENTER">
        <Button text="💾 Сохранить"
                onAction="#handleSaveTask"
                styleClass="primary-btn" />
        <Button fx:id="btnCancel" text="❌ Отмена"
                onAction="#handleCancel"
                styleClass="secondary-btn" />
    </HBox>

</VBox>