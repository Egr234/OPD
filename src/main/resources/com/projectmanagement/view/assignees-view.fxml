<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<GridPane xmlns="http://javafx.com/javafx/17.0.2"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.projectmanagement.controller.AssigneeController"
          hgap="15" vgap="15">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <columnConstraints>
        <ColumnConstraints percentWidth="65" />
        <ColumnConstraints percentWidth="35" />
    </columnConstraints>

    <rowConstraints>
        <RowConstraints percentHeight="60" />
        <RowConstraints percentHeight="40" />
    </rowConstraints>

    <!-- Левая часть: Список разработчиков -->
    <VBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.rowSpan="2">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="👥 Управление разработчиками" styleClass="header-label">
                <font>
                    <Font name="System Bold" size="18" />
                </font>
            </Label>
            <Label fx:id="lblAssigneeStats" text=""
                   style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="🔄 Обновить" onAction="#handleRefresh"
                    styleClass="secondary-btn" />
        </HBox>

        <!-- Поиск -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Поиск:" />
            <TextField fx:id="tfSearchAssignee"
                       promptText="Поиск по имени..."
                       HBox.hgrow="ALWAYS" />
        </HBox>

        <!-- Таблица разработчиков -->
        <TableView fx:id="assigneeTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colAssigneeId" text="ID" prefWidth="50" />
                <TableColumn fx:id="colFullName" text="ФИО" prefWidth="200" />
                <TableColumn fx:id="colPosition" text="Должность" prefWidth="150" />
                <TableColumn fx:id="colDepartment" text="Отдел" prefWidth="120" />
                <TableColumn fx:id="colEmail" text="Email" prefWidth="180" />
                <TableColumn fx:id="colTaskCount" text="Активных задач" prefWidth="100" />
                <TableColumn fx:id="colStatus" text="Статус" prefWidth="80" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>

    <!-- Правая верхняя часть: Форма разработчика -->
    <VBox spacing="15" styleClass="form-panel"
          GridPane.columnIndex="1" GridPane.rowIndex="0">
        <Label text="✏️ Форма разработчика" styleClass="header-label">
            <font>
                <Font name="System Bold" size="16" />
            </font>
        </Label>

        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints percentWidth="35" />
                <ColumnConstraints percentWidth="65" />
            </columnConstraints>

            <rowConstraints>
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
            </rowConstraints>

            <!-- ФИО -->
            <Label text="ФИО*:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="tfFullName"
                       promptText="Введите ФИО полностью"
                       GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <!-- Email -->
            <Label text="Email*:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="tfEmail"
                       promptText="example@company.com"
                       GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <!-- Должность -->
            <Label text="Должность:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="tfPosition"
                       promptText="Разработчик, Дизайнер и т.д."
                       GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <!-- Отдел -->
            <Label text="Отдел:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <TextField fx:id="tfDepartment"
                       promptText="IT, Дизайн, Маркетинг"
                       GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <!-- Телефон -->
            <Label text="Телефон:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
            <TextField fx:id="tfPhone"
                       promptText="+7 (XXX) XXX-XX-XX"
                       GridPane.columnIndex="1" GridPane.rowIndex="4" />

            <!-- Статус -->
            <Label text="Статус:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
            <ComboBox fx:id="cbActiveStatus"
                      GridPane.columnIndex="1" GridPane.rowIndex="5" />
        </GridPane>

        <!-- Кнопки действий -->
        <HBox spacing="10" alignment="CENTER">
            <Button fx:id="btnAddAssignee" text="➕ Добавить"
                    onAction="#handleAddAssignee" styleClass="primary-btn" />
            <Button fx:id="btnUpdateAssignee" text="✏️ Обновить"
                    onAction="#handleUpdateAssignee" styleClass="secondary-btn"
                    disable="true" />
            <Button fx:id="btnDeleteAssignee" text="🗑️ Удалить"
                    onAction="#handleDeleteAssignee" styleClass="danger-btn"
                    disable="true" />
            <Button fx:id="btnClearAssignee" text="❌ Очистить"
                    onAction="#handleClearForm" styleClass="secondary-btn" />
        </HBox>
    </VBox>

    <!-- Правая нижняя часть: Статистика разработчика -->
    <VBox spacing="10" styleClass="form-panel"
          GridPane.columnIndex="1" GridPane.rowIndex="1">
        <Label text="📊 Статистика разработчика" styleClass="header-label">
            <font>
                <Font name="System Bold" size="16" />
            </font>
        </Label>

        <VBox spacing="8" fx:id="assigneeStatsBox">
            <!-- Статистика будет заполняться динамически -->
            <Label text="Выберите разработчика для просмотра статистики"
                   style="-fx-text-fill: #7f8c8d; -fx-font-style: italic;" />
        </VBox>
    </VBox>

</GridPane>